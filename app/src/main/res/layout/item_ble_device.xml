<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Device info column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDeviceName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    tools:text="TurboMesh Node 1" />

                <!-- MESH badge shown only for mesh nodes -->
                <TextView
                    android:id="@+id/tvMeshBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@color/purple_500"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="MESH"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@android:color/white"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDeviceAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="monospace"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?android:attr/textColorSecondary"
                tools:text="AA:BB:CC:DD:EE:FF" />

            <TextView
                android:id="@+id/tvDeviceRssi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorSecondary"
                tools:text="Strong (-55 dBm)" />

            <!-- Service UUIDs (collapsible) -->
            <TextView
                android:id="@+id/tvServiceUuids"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:textColor="?android:attr/textColorSecondary"
                android:visibility="gone"
                tools:text="00001827-0000-1000-8000-00805f9b34fb" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
